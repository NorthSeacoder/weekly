{
    "extends": "astro/tsconfigs/base",
    "compilerOptions": {
        "strictNullChecks": true,
        "allowJs": true,
        "baseUrl": ".",
        "paths": {
            "@/*": ["*"],
            "~/*": ["src/*"] 
        },
    },
    "include": [".astro/types.d.ts", "src/**/*", "lib/**/*", "integration/**/*", "types/**/*", "config/**/*", "astro.config.ts", "tailwind.config.ts"],
    "exclude": ["node_modules", "archive/**/*", "src/archive/**/*", "extension/**/*", "scripts/**/*", "dist/", "types/tempCodeRunnerFile.ts", "lib/tag.ts"]
}
