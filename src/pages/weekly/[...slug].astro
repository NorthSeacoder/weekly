---
import Layout from '~/layouts/PageLayout.astro';
import SinglePost from '~/components/pages/SinglePost.astro';
import type { InferGetStaticPropsType, GetStaticPaths } from 'astro';
import { getStaticPathsWeeklyPost, getWeeklyPostWithSectionsBySlug } from '~/utils/contents/unified-content';

export const getStaticPaths = (async () => {
  const paths = await getStaticPathsWeeklyPost();
  
  // 为每个文章添加前一篇和后一篇的引用
  return paths.map((path, index) => {
    const prevPost = index > 0 ? paths[index - 1].props.post : undefined;
    const nextPost = index < paths.length - 1 ? paths[index + 1].props.post : undefined;
    
    return {
      ...path,
      props: {
        prevPost,
        nextPost,
      },
    };
  });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { prevPost, nextPost } = Astro.props as Props;
const rawSlug = Astro.params.slug;
const slug = Array.isArray(rawSlug) ? rawSlug.join('/') : rawSlug;
const post = slug ? await getWeeklyPostWithSectionsBySlug(slug) : null;

const ogImageUrl = post?.issueNumber
  ? new URL(`/og/weekly/${post.issueNumber}.png`, Astro.site).toString()
  : undefined;

const metadata = post
  ? {
      title: post.title,
      description: post.desc || `第 ${post.issueNumber} 期周刊`,
      openGraph: {
        type: 'article',
        images: ogImageUrl
          ? [{ url: ogImageUrl, width: 1200, height: 630 }]
          : [],
      },
      twitter: {
        cardType: ogImageUrl ? 'summary_large_image' : 'summary',
      },
    }
  : undefined;
---

<Layout metadata={metadata}>
  {post && <SinglePost post={post} prevPost={prevPost} nextPost={nextPost} />}
</Layout>
