---
import Layout from '~/layouts/PageLayout.astro';
import LatestWeeklyList from '~/components/pages/LatestWeeklyList.astro';
import Button from '~/components/ui/Button.astro';
import {getWeeklyPosts} from '~/utils/contents/unified-content';

const weeklyList = await getWeeklyPosts();
const latestWeekly = weeklyList[0];
const totalIssues = weeklyList.length;
const latestDate = latestWeekly
    ? new Date(latestWeekly.date).toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'long',
          day: 'numeric'
      })
    : null;

const metadata = {
    title: '我不知道的周刊',
    ignoreTitleTemplate: true
};
---

<Layout metadata={metadata}>
    <section class='home-hero'>
        <div class='hero-shell'>
            <div class='hero-copy'>
                <div class='hero-eyebrow'>
                    <span class='hero-dot'></span>
                    <span>每周更新</span>
                </div>

                <div class='hero-heading'>
                    <p class='hero-kicker'>前端 / AI 工具 / 独立开发</p>
                    <h1>把这一周值得读的内容，先看一遍。</h1>
                    <p class='hero-lead'>
                        每周整理前端、AI 工具与独立开发方向里值得阅读与回看的内容。
                    </p>
                </div>

                <div class='hero-actions'>
                    <Button href={latestWeekly?.permalink || '/weekly'} variant='primary' size='lg' class='hero-primary-action'>
                        {latestWeekly ? '从最新一期开始' : '进入周刊'}
                    </Button>
                    <Button href='/weekly' variant='secondary' size='lg'>浏览全部归档</Button>
                </div>

                <dl class='hero-metrics'>
                    <div>
                        <dt>已发布期数</dt>
                        <dd>{totalIssues}</dd>
                    </div>
                    <div>
                        <dt>更新节奏</dt>
                        <dd>每周一刊</dd>
                    </div>
                    <div>
                        <dt>内容方向</dt>
                        <dd>技术精选</dd>
                    </div>
                </dl>
            </div>

            <aside class='hero-latest'>
                <div class='latest-frame'>
                    <div class='latest-label'>这一期</div>
                    {
                        latestWeekly ? (
                            <>
                                <p class='latest-date'>{latestDate}</p>
                                <h2>{latestWeekly.title}</h2>
                                <p class='latest-desc'>
                                    {latestWeekly.desc || '本期整理了前端与 AI 方向里近期值得留意的内容。'}
                                </p>
                                <div class='latest-actions'>
                                    <a href={latestWeekly.permalink} class='latest-link'>
                                        打开本期
                                    </a>
                                    <span class='latest-note'>先快速浏览，再按兴趣继续细读。</span>
                                </div>
                            </>
                        ) : (
                            <>
                                <p class='latest-date'>内容整理中</p>
                                <h2>新的周刊即将发布</h2>
                                <p class='latest-desc'>
                                    目前还没有可展示的周刊内容，稍后再来。
                                </p>
                            </>
                        )
                    }
                </div>
            </aside>
        </div>
    </section>

    <section id='latest-content' class='scroll-mt-20'>
        <LatestWeeklyList />
    </section>
</Layout>

<style>
    .home-hero {
        position: relative;
        overflow: hidden;
        margin-top: -68px;
        padding: calc(2rem + 68px) 1.5rem 2rem;
        background:
            radial-gradient(circle at top left, hsl(var(--primary) / 0.08), transparent 30%),
            linear-gradient(180deg, hsl(var(--surface)) 0%, hsl(var(--background)) 72%);
    }

    .hero-shell {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(18rem, 0.9fr);
        gap: 2rem;
        align-items: start;
        max-width: 72rem;
        margin: 0 auto;
    }

    .hero-copy {
        display: grid;
        gap: 2rem;
    }

    .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.625rem;
        width: fit-content;
        padding: 0.375rem 0.875rem;
        border: 1px solid hsl(var(--border));
        border-radius: 999px;
        background: hsl(var(--background) / 0.88);
        color: hsl(var(--muted-foreground));
        font-size: 0.875rem;
        font-weight: 500;
    }

    .hero-dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 999px;
        background: hsl(var(--primary));
        box-shadow: 0 0 0 6px hsl(var(--primary) / 0.14);
    }

    .hero-heading {
        display: grid;
        gap: 1rem;
        max-width: 42rem;
    }

    .hero-kicker {
        color: hsl(var(--primary));
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .hero-heading h1 {
        margin: 0;
        max-width: 11ch;
        font-size: clamp(3rem, 7vw, 5.5rem);
        line-height: 0.98;
        letter-spacing: -0.045em;
        text-wrap: balance;
    }

    .hero-lead {
        max-width: 34rem;
        color: hsl(var(--muted-foreground));
        font-size: 1.125rem;
        line-height: 1.8;
        text-wrap: pretty;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.875rem;
    }

    .hero-primary-action {
        box-shadow: 0 10px 25px -16px hsl(var(--primary) / 0.55);
    }

    .hero-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        max-width: 42rem;
        margin: 0;
    }

    .hero-metrics div {
        padding-top: 1rem;
        border-top: 1px solid hsl(var(--border));
    }

    .hero-metrics dt {
        color: hsl(var(--muted-foreground));
        font-size: 0.8125rem;
        margin-bottom: 0.5rem;
    }

    .hero-metrics dd {
        margin: 0;
        color: hsl(var(--foreground));
        font-size: 1.125rem;
        font-weight: 700;
    }

    .hero-latest {
        min-width: 0;
        align-self: end;
    }

    .latest-frame {
        display: grid;
        gap: 1rem;
        padding: 1.5rem;
        border: 1px solid hsl(var(--border));
        border-radius: 1.25rem;
        background:
            linear-gradient(180deg, hsl(var(--background)) 0%, hsl(var(--surface)) 100%);
        box-shadow: 0 18px 40px -32px rgba(17, 21, 26, 0.35);
    }

    .latest-label {
        width: fit-content;
        padding: 0.25rem 0.625rem;
        border-radius: 999px;
        background: hsl(var(--primary) / 0.09);
        color: hsl(var(--primary));
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .latest-date {
        color: hsl(var(--muted-foreground));
        font-size: 0.875rem;
        margin: 0;
    }

    .latest-frame h2 {
        margin: 0;
        font-size: clamp(1.65rem, 3vw, 2.4rem);
        line-height: 1.12;
        text-wrap: balance;
    }

    .latest-desc {
        margin: 0;
        color: hsl(var(--muted-foreground));
        line-height: 1.75;
    }

    .latest-actions {
        display: grid;
        gap: 0.5rem;
        padding-top: 1rem;
        border-top: 1px solid hsl(var(--border));
    }

    .latest-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        width: fit-content;
        color: hsl(var(--foreground));
        font-weight: 700;
        text-decoration: none;
    }

    .latest-link:hover {
        color: hsl(var(--primary));
    }

    .latest-note {
        color: hsl(var(--muted-foreground));
        font-size: 0.875rem;
    }

    @media (max-width: 1024px) {
        .hero-shell {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .hero-heading h1 {
            max-width: 12ch;
        }

        .hero-latest {
            max-width: 40rem;
        }
    }

    @media (max-width: 640px) {
        .home-hero {
            margin-top: -68px;
            padding: calc(1.25rem + 68px) 1rem 1.5rem;
        }

        .hero-copy,
        .hero-heading {
            gap: 1.25rem;
        }

        .hero-heading h1 {
            max-width: 9ch;
            font-size: clamp(2.5rem, 13vw, 4rem);
        }

        .hero-lead {
            font-size: 1rem;
            line-height: 1.65;
        }

        .hero-actions {
            display: grid;
            grid-template-columns: 1fr;
        }

        .hero-actions :global(a),
        .hero-actions :global(button) {
            width: 100%;
            justify-content: center;
        }

        .hero-metrics {
            grid-template-columns: 1fr;
        }

        .latest-frame {
            padding: 1.125rem;
            border-radius: 1rem;
        }

        .latest-frame h2 {
            font-size: 1.5rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .home-hero *,
        .home-hero *::before,
        .home-hero *::after {
            transition-duration: 0.01ms !important;
        }
    }
</style>
