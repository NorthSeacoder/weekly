---
import Layout from '~/layouts/PageLayout.astro';
import LatestWeeklyList from '~/components/pages/LatestWeeklyList.astro';
import Button from '~/components/ui/Button.astro';
import {Icon} from 'astro-icon/components';
import {getWeeklyPosts} from '~/utils/contents/unified-content';

const weeklyList = await getWeeklyPosts();
const latestWeekly = weeklyList[0];
const totalIssues = weeklyList.length;

const metadata = {
    title: '我不知道的周刊',
    ignoreTitleTemplate: true
};
---

<Layout metadata={metadata}>
    <section class='home-hero'>
        <div class='hero-shell'>
            <div class='hero-main neu-raised'>
                <div class='hero-copy'>
                    <h1 class='hero-heading'>
                        我不知道的<br />周刊
                    </h1>

                    <p class='hero-lead'>
                        每周精选前端、AI 工具与独立开发内容，记录那些「原来还能这样」的时刻。
                    </p>

                    <div class='hero-actions'>
                        <Button href={latestWeekly?.permalink || '/weekly'} variant='primary' size='lg'>
                            阅读最新一期
                        </Button>
                        <Button href='/weekly' variant='secondary' size='lg'>
                            浏览全部 {totalIssues} 期
                        </Button>
                    </div>
                </div>

                {latestWeekly && (
                    <a href={latestWeekly.permalink} class='hero-issue neu-inset'>
                        <div class='issue-number'>#{latestWeekly.issueNumber || totalIssues}</div>
                        <div class='issue-body'>
                            <span class='issue-label'>Latest</span>
                            <h2>{latestWeekly.title}</h2>
                            <div class='issue-meta'>
                                <span>{latestWeekly.sections?.length || 0} 条内容</span>
                                <Icon name='tabler:arrow-right' class='issue-arrow' />
                            </div>
                        </div>
                    </a>
                )}
            </div>
        </div>
    </section>

    <section id='latest-content' class='scroll-mt-20'>
        <LatestWeeklyList />
    </section>
</Layout>

<style>
    .home-hero {
        position: relative;
        overflow: hidden;
        padding: 6.5rem 1.5rem 2.25rem;
        background:
            radial-gradient(ellipse 60% 38% at 72% 0%, hsl(var(--primary) / 0.1), transparent 64%),
            transparent;
    }

    .hero-shell {
        max-width: 72rem;
        margin: 0 auto;
    }

    .hero-main {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(18rem, 0.75fr);
        align-items: stretch;
        gap: 1.25rem;
        padding: clamp(1.25rem, 4vw, 2rem);
        border-radius: 0.875rem;
        background: var(--neu-surface-gradient);
        box-shadow: var(--shadow-lg);
    }

    .hero-main::before {
        content: '';
        position: absolute;
        inset: 1rem;
        border-radius: 0.625rem;
        border: 1px solid hsl(var(--border) / 0.45);
        pointer-events: none;
    }

    .hero-copy {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 1rem;
        padding: clamp(0.25rem, 2vw, 1rem);
    }

    .hero-heading {
        margin: 0;
        font-size: clamp(3.1rem, 7vw, 5.8rem);
        font-weight: 800;
        line-height: 0.94;
        letter-spacing: -0.025em;
        color: hsl(var(--foreground));
    }

    .hero-lead {
        margin: 0;
        max-width: 36rem;
        font-size: 1.0625rem;
        line-height: 1.65;
        color: hsl(var(--muted-foreground));
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        padding-top: 0.125rem;
    }

    .hero-issue {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        min-height: 18rem;
        padding: 1.25rem;
        border-radius: 0.75rem;
        background: var(--neu-inset-gradient);
        box-shadow: var(--shadow-inner);
        text-decoration: none;
        color: hsl(var(--foreground));
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .hero-issue:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-sm);
    }

    .issue-number {
        align-self: flex-start;
        color: hsl(var(--primary));
        font-size: clamp(3rem, 7vw, 5.25rem);
        font-weight: 800;
        line-height: 0.9;
        letter-spacing: -0.04em;
        opacity: 0.86;
        font-variant-numeric: tabular-nums;
    }

    .issue-body {
        display: grid;
        gap: 0.75rem;
    }

    .issue-label {
        color: hsl(var(--muted-foreground));
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .issue-body h2 {
        margin: 0;
        max-width: 24rem;
        font-size: clamp(1.35rem, 3vw, 2rem);
        font-weight: 800;
        line-height: 1.18;
        letter-spacing: -0.02em;
    }

    .issue-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        padding-top: 0.5rem;
        border-top: 1px solid hsl(var(--border) / 0.6);
        font-size: 0.8125rem;
        font-weight: 600;
        color: hsl(var(--muted-foreground));
    }

    .issue-arrow {
        width: 1rem;
        height: 1rem;
        color: hsl(var(--muted-foreground));
        transition: transform 0.2s ease, color 0.2s ease;
    }

    .hero-issue:hover .issue-arrow {
        transform: translateX(3px);
        color: hsl(var(--primary));
    }

    @media (max-width: 820px) {
        .hero-main {
            grid-template-columns: 1fr;
        }

        .hero-issue {
            min-height: 14rem;
        }
    }

    @media (max-width: 640px) {
        .home-hero {
            padding: 5rem 1rem 1.5rem;
        }

        .hero-main {
            padding: 1rem;
        }

        .hero-heading {
            font-size: clamp(2.5rem, 12vw, 4rem);
        }

        .hero-lead {
            font-size: 1rem;
            line-height: 1.6;
        }

        .hero-actions {
            flex-direction: column;
            width: 100%;
        }

        .hero-actions :global(a) {
            width: 100%;
            justify-content: center;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .home-hero * {
            transition: none !important;
        }
    }
</style>
