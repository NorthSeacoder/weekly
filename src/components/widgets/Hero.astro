---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import { cn } from '~/utils/utils';

import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,

  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),

  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative min-h-[70vh] flex items-center overflow-hidden bg-background" {...id ? { id } : {}}>
  <!-- VSCode style: clean background, no gradients -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <slot name="bg">
      {bg ? <Fragment set:html={bg} /> : null}
    </slot>
  </div>

  <div class="relative w-full max-w-5xl mx-auto px-6 sm:px-8 py-20 md:py-28">
    <div class="text-center space-y-8">
      <!-- Tagline badge - VSCode style -->
      {tagline && (
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded border border-border bg-surface animate-fade-in-down">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
          <span class="text-sm font-medium text-muted-foreground">
            <Fragment set:html={tagline} />
          </span>
        </div>
      )}

      <!-- Title -->
      {title && (
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.1] tracking-tight text-foreground animate-text-reveal">
          <Fragment set:html={title} />
        </h1>
      )}

      <!-- Subtitle -->
      {subtitle && (
        <div class="max-w-2xl mx-auto text-lg md:text-xl text-muted-foreground leading-relaxed animate-fade-in-up" style="animation-delay: 0.2s;">
          <Fragment set:html={subtitle} />
        </div>
      )}

      <!-- Actions - Linear style buttons -->
      {actions && (
        <div class="flex flex-wrap gap-3 justify-center items-center pt-4 animate-fade-in-up" style="animation-delay: 0.3s;">
          {Array.isArray(actions) ? (
            actions.map((action, index) => (
              <Button
                variant={action?.variant || (index === 0 ? 'primary' : 'secondary')}
                size="lg"
                href={action?.href?.toString() || undefined}
                target={action?.target || undefined}
                rel={action?.rel || undefined}
                class={cn("min-w-[140px]", action?.class)}
              >
                {action?.text || action?.title}
              </Button>
            ))
          ) : (
            <Fragment set:html={actions} />
          )}
        </div>
      )}
    </div>

    <!-- Image section -->
    {image && (
      <div class="mt-16 md:mt-20 animate-fade-in-up" style="animation-delay: 0.4s;">
        <div class="relative mx-auto max-w-4xl">
          <div class="relative rounded border border-border bg-card shadow-lg overflow-hidden">
            {typeof image === 'string' ? (
              <Fragment set:html={image} />
            ) : (
              <Image
                class="w-full object-cover"
                widths={[400, 768, 1024, 2040]}
                sizes="(max-width: 767px) 400px, (max-width: 1023px) 768px, (max-width: 2039px) 1024px, 2040px"
                loading="eager"
                width={1024}
                height={576}
                {...image}
              />
            )}
          </div>
        </div>
      </div>
    )}

    <!-- Content slot -->
    {content && (
      <div class="mt-12 animate-fade-in-up" style="animation-delay: 0.5s;">
        <Fragment set:html={content} />
      </div>
    )}
  </div>
</section>

<style>
  /* Linear-style animations */
  @keyframes fade-in-down {
    0% {
      opacity: 0;
      transform: translateY(-12px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in-up {
    0% {
      opacity: 0;
      transform: translateY(16px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes text-reveal {
    0% {
      opacity: 0;
      transform: translateY(20px);
      filter: blur(8px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .animate-fade-in-down {
    animation: fade-in-down 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .animate-text-reveal {
    animation: text-reveal 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: 0.1s;
  }

  /* Text gradient utility */
  .text-gradient {
    background: linear-gradient(180deg, hsl(var(--foreground)) 0%, hsl(var(--foreground) / 0.6) 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Typography optimization */
  h1 {
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    font-feature-settings: "cv02", "cv03", "cv04", "cv11";
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      transition-duration: 0.01ms !important;
    }
  }

  /* High contrast mode */
  @media (prefers-contrast: high) {
    .text-gradient {
      background: none !important;
      color: hsl(var(--foreground)) !important;
      -webkit-background-clip: unset !important;
      background-clip: unset !important;
    }
  }
</style>
