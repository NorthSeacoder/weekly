---
import {Icon} from 'astro-icon/components';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import {getLatestWeeklyPost} from '~/utils/contents/unified-content';
import {trimSlash, getHomePermalink, getPermalink} from '~/utils/permalinks';

interface Link {
    text?: string;
    href?: string;
    ariaLabel?: string;
    icon?: string;
}

export interface Props {
    id?: string;
}

const {id = 'header'} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
const links: Array<Link> = [
    {text: '首页', href: getPermalink('/'), icon: 'tabler:home'},
    {text: '周刊', href: getPermalink('/weekly'), icon: 'tabler:news'}
];
const latestWeekly = await getLatestWeeklyPost();
---

<header
    class='fixed top-0 left-0 right-0 z-50 mx-auto w-full site-header'
    {...id ? {id} : {}}
    data-header
    transition:persist="main-header"
>
    <div class='site-header-inner mx-auto w-full max-w-[68rem] px-4' data-header-inner>
        <!-- 导航容器 -->
        <div class='site-header-shell relative w-full px-0 py-2'>
            <div class='flex min-h-12 items-center justify-between gap-3 sm:gap-4'>
                <!-- 左侧: Logo + 导航 -->
                <div class='flex min-w-0 items-center gap-4 sm:gap-6'>
                    <!-- Logo -->
                    <a
                        class='flex shrink-0 items-center gap-2 rounded-md px-1 py-1 transition-colors hover:bg-surface-hover/45 group/logo'
                        href={getHomePermalink()}
                        aria-label='回到首页'>
                        <div class='w-7 h-7 flex items-center justify-center rounded-md bg-primary/90 transition-colors group-hover/logo:bg-primary'>
                            <Icon name='tabler:code' class='w-3.5 h-3.5 text-primary-foreground' />
                        </div>
                        <span class='hidden whitespace-nowrap sm:block text-sm font-semibold text-foreground'>
                            我不知道的周刊
                        </span>
                    </a>

                    <!-- 桌面导航 -->
                    <nav class='hidden md:flex items-center gap-1' aria-label='主导航'>
                        {
                            links.map(({text, href, icon}) => (
                                <a
                                    class:list={[
                                        'flex items-center gap-1.5 whitespace-nowrap px-3 py-1.5 rounded-md text-sm font-medium transition-colors',
                                        href === currentPath
                                            ? 'text-primary bg-primary/10'
                                            : 'text-muted-foreground hover:text-foreground hover:bg-surface-hover/45'
                                    ]}
                                    href={href}
                                    data-nav-link>
                                    {icon && <Icon name={icon} class='w-4 h-4' />}
                                    <span>{text}</span>
                                </a>
                            ))
                        }
                    </nav>
                </div>

                <!-- 右侧: 工具栏 -->
                <div class='flex shrink-0 items-center gap-2'>
                    <!-- 最新周刊 (大屏幕) -->
                    {
                        latestWeekly && (
                            <a
                                href={latestWeekly.permalink}
                                class='hidden xl:flex items-center gap-2 px-2.5 py-1.5 rounded-md text-muted-foreground hover:text-primary hover:bg-primary/10 transition-colors mr-1'>
                                <span class='h-1.5 w-1.5 rounded-full bg-primary/75' />
                                <span class='text-xs font-medium max-w-[120px] truncate'>
                                    {latestWeekly.title}
                                </span>
                            </a>
                        )
                    }

                    <!-- 搜索按钮 -->
                    <button
                        type='button'
                        class='flex shrink-0 items-center gap-1.5 h-8 px-2.5 rounded-md text-muted-foreground hover:text-foreground hover:bg-surface-hover/45 transition-colors cursor-pointer'
                        aria-label='搜索'
                        data-search-trigger
                        id='header-search-btn'>
                        <Icon name='tabler:search' class='w-3.5 h-3.5' />
                        <kbd class='hidden sm:inline text-[10px] font-mono text-muted-foreground bg-surface-hover/55 px-1.5 py-0.5 rounded'>
                            ⌘K
                        </kbd>
                    </button>

                    <!-- GitHub -->
                    <a
                        class='flex shrink-0 items-center justify-center w-8 h-8 rounded-md text-muted-foreground hover:text-foreground hover:bg-surface-hover/45 transition-colors'
                        aria-label='GitHub'
                        href='https://github.com/NorthSeacoder/weekly'
                        target='_blank'
                        rel='noopener'>
                        <Icon name='tabler:brand-github' class='w-3.5 h-3.5' />
                    </a>

                    <!-- 移动端菜单按钮 -->
                    <div class='md:hidden'>
                        <ToggleMenu
                            class='group flex h-8 w-8 flex-col items-center justify-center rounded-md text-muted-foreground hover:text-foreground hover:bg-surface-hover/45 transition-colors'
                        />
                    </div>
                </div>
            </div>

            <!-- 移动端导航菜单 -->
            <nav
                class='md:hidden hidden absolute top-full left-0 right-0 mt-2 p-2 rounded-md bg-background/95 border border-border/60 shadow-lg backdrop-blur-md'
                data-mobile-menu>
                {
                    links.map(({text, href, icon}) => (
                        <a
                            class:list={[
                                'flex items-center gap-3 px-4 py-3 rounded-md text-sm font-medium transition-colors',
                                href === currentPath
                                    ? 'text-primary bg-primary/10'
                                    : 'text-muted-foreground hover:text-foreground hover:bg-surface-hover'
                            ]}
                            href={href}
                            data-nav-link-mobile>
                            {icon && <Icon name={icon} class='w-5 h-5' />}
                            <span>{text}</span>
                        </a>
                    ))
                }

                <div class='my-2 h-px bg-border'></div>

                <button
                    type='button'
                    class='w-full flex items-center gap-3 px-4 py-3 rounded-md text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-surface-hover transition-colors'
                    data-search-trigger
                    id='mobile-search-btn'>
                    <Icon name='tabler:search' class='w-5 h-5' />
                    <span>搜索</span>
                </button>

                {
                    latestWeekly && (
                        <a
                            href={latestWeekly.permalink}
                            class='flex items-center gap-3 px-4 py-3 rounded-md text-sm font-medium text-primary hover:bg-primary/10 transition-colors'>
                            <span class='h-1.5 w-1.5 rounded-full bg-primary/75' />
                            <span class='truncate'>{latestWeekly.title}</span>
                        </a>
                    )
                }
            </nav>
        </div>
    </div>
</header>

<script>
    (function () {
        let abortController: AbortController | undefined;

        function initHeader() {
            if (abortController) abortController.abort();
            abortController = new AbortController();
            const signal = abortController.signal;

            const headerInner = document.querySelector('[data-header-inner]') as HTMLElement | null;
            const mobileMenu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;
            const toggleButton = document.querySelector('[data-aw-toggle-menu]') as HTMLElement | null;

            if (!headerInner) return;

            function normalizePath(path: string) {
                const clean = (path || '/').split('?')[0].split('#')[0];
                return clean === '/' ? '/' : clean.replace(/\/$/, '');
            }

            function setActiveLinks(targetPath: string) {
                const normalizedTarget = normalizePath(targetPath);
                document.querySelectorAll('[data-nav-link], [data-nav-link-mobile]').forEach((link) => {
                    const href = normalizePath(link.getAttribute('href') || '/');
                    const isActive = href === normalizedTarget;

                    if (isActive) {
                        link.classList.add('text-primary', 'bg-primary/10');
                        link.classList.remove('text-muted-foreground');
                    } else {
                        link.classList.remove('text-primary', 'bg-primary/10');
                        link.classList.add('text-muted-foreground');
                    }
                });
            }

            // 立即根据当前地址同步一次（解决 persist 后的“旧高亮”）
            setActiveLinks(window.location.pathname);

            // 点击导航时立即更新高亮，避免导航过渡期间闪一下
            document.querySelectorAll('[data-nav-link], [data-nav-link-mobile]').forEach((link) => {
                link.addEventListener(
                    'click',
                    () => {
                        const href = link.getAttribute('href');
                        if (href) setActiveLinks(href);
                    },
                    { signal }
                );
            });

            // 移动端菜单切换
            function toggleMobileMenu() {
                if (!mobileMenu || !toggleButton) return;

                const isExpanded = toggleButton.getAttribute('aria-expanded') === 'true';
                toggleButton.setAttribute('aria-expanded', (!isExpanded).toString());
                toggleButton.classList.toggle('expanded', !isExpanded);

                if (!isExpanded) {
                    mobileMenu.classList.remove('hidden');
                    mobileMenu.style.opacity = '0';
                    mobileMenu.style.transform = 'translateY(-8px)';
                    requestAnimationFrame(() => {
                        mobileMenu.style.transition = 'all 0.2s ease-out';
                        mobileMenu.style.opacity = '1';
                        mobileMenu.style.transform = 'translateY(0)';
                    });
                } else {
                    mobileMenu.style.opacity = '0';
                    mobileMenu.style.transform = 'translateY(-8px)';
                    setTimeout(() => mobileMenu.classList.add('hidden'), 200);
                }
            }

            if (toggleButton) {
                toggleButton.addEventListener('click', toggleMobileMenu, { signal });
            }

            // 点击外部关闭菜单
            document.addEventListener(
                'click',
                (e) => {
                    if (mobileMenu && !mobileMenu.contains(e.target as Node) && !toggleButton?.contains(e.target as Node)) {
                        if (!mobileMenu.classList.contains('hidden')) {
                            toggleMobileMenu();
                        }
                    }
                },
                { signal }
            );

            // 搜索触发
            document.querySelectorAll('[data-search-trigger]').forEach((btn) => {
                btn.addEventListener(
                    'click',
                    () => {
                        const searchModalBtn = document.querySelector('[data-aw-search-modal-trigger]');
                        if (searchModalBtn) (searchModalBtn as HTMLElement).click();
                    },
                    { signal }
                );
            });

            // 键盘快捷键
            document.addEventListener(
                'keydown',
                (e) => {
                    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                        e.preventDefault();
                        const searchBtn = document.querySelector('[data-search-trigger]') as HTMLElement | null;
                        searchBtn?.click();
                    }
                },
                { signal }
            );
        }

        document.addEventListener('astro:page-load', initHeader);
    })();
</script>

<style>
    .site-header {
        background-color: hsl(var(--background) / 0.78);
        border-bottom: 1px solid hsl(var(--border) / 0.48);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 1px 0 hsl(var(--foreground) / 0.03);
    }

    .site-header-shell {
        background: transparent;
        border: 0;
        box-shadow: none;
    }

    .header-bg {
        box-shadow: 0 1px 1px hsl(var(--foreground) / 0.04);
    }
</style>
