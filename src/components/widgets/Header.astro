---
import {Icon} from 'astro-icon/components';
import ToggleMenu from '~/components/common/ToggleMenu.astro';
import { getWeeklyPosts } from '~/utils/contents/unified-content';
import Button from '~/components/ui/Button.astro';
import {trimSlash, getAsset, getHomePermalink, getPermalink} from '~/utils/permalinks';
import type {CallToAction} from '~/types';

interface Link {
    text?: string;
    href?: string;
    ariaLabel?: string;
    icon?: string;
    links?: Link[];
}

export interface Props {
    id?: string;
    isSticky?: boolean;
    isDark?: boolean;
    isFullWidth?: boolean;
    showRssFeed?: boolean;
    showEmail?: boolean;
    position?: string;
}

const {
    id = 'header',
    isSticky = false,
    isDark = false,
    isFullWidth = false,
    showRssFeed = false,
    showEmail = false,
    position = 'center'
} = Astro.props;

const currentPath = `/${trimSlash(new URL(Astro.url).pathname)}`;
const links: Array<Link> = [
    { text: '首页', href: getPermalink('/'), icon: 'tabler:home' },
    { text: '周刊', href: getPermalink('/weekly'), icon: 'tabler:news' },
];
const actions: Array<CallToAction> = [];
const weekly = await getWeeklyPosts();
const latestWeekly = weekly?.[0];
---

<header
    class="fixed top-0 left-0 right-0 z-50 header-container bg-background/80 backdrop-blur-xl"
    {...id ? { id } : {}}
    data-header>

    <!-- 顶部装饰线 -->
    <div class="absolute inset-x-0 top-0 h-[1px] bg-gradient-to-r from-transparent via-primary/50 to-transparent opacity-0 transition-opacity duration-500" data-header-glow></div>

    <div class="relative mx-auto w-full max-w-7xl px-4 sm:px-6 py-1.5">
        <div class="header-inner flex items-center justify-between gap-3">

            <!-- 左侧: Logo + 导航 -->
            <div class="flex items-center gap-4">
                <!-- Logo -->
                <a
                    class="flex items-center gap-2 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded"
                    href={getHomePermalink()}
                    aria-label="回到首页"
                >
                    <div class="w-6 h-6 rounded bg-primary flex items-center justify-center">
                        <Icon name="tabler:rocket" class="w-3.5 h-3.5 text-white" />
                    </div>
                    <span class="hidden sm:block text-sm font-semibold text-foreground">
                        我不知道的周刊
                    </span>
                </a>

                <!-- 桌面导航 -->
                <nav class="hidden md:flex items-center" aria-label="主导航">
                    <div class="flex items-center gap-0.5 p-0.5 rounded-md bg-secondary/30 border border-border/20">
                        {links.map(({ text, href, icon }) => (
                            <a
                                class:list={[
                                    'nav-link group/nav relative flex items-center gap-1.5 px-3 py-1 rounded text-sm font-medium',
                                    'transition-all duration-200',
                                    'focus:outline-none focus-visible:ring-2 focus-visible:ring-primary',
                                    'active:scale-95',
                                    {
                                        'text-foreground bg-background shadow-sm border border-border/50': href === currentPath,
                                        'text-muted-foreground hover:text-foreground hover:bg-secondary/50': href !== currentPath,
                                    },
                                ]}
                                href={href}
                            >
                                {icon && <Icon name={icon} class="w-3.5 h-3.5 opacity-60 group-hover/nav:opacity-100 transition-opacity" />}
                                <span>{text}</span>
                            </a>
                        ))}
                    </div>
                </nav>
            </div>

            <!-- 中间: 最新周刊提示 (大屏幕) -->
            {latestWeekly && (
                <a
                    href={latestWeekly.permalink}
                    class="hidden xl:flex items-center gap-3 px-4 py-2 rounded-lg bg-gradient-to-r from-primary/5 to-primary/10 border border-primary/20 hover:border-primary/40 transition-all duration-300 group/latest"
                >
                    <div class="flex items-center gap-2">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                        </span>
                        <span class="text-xs font-semibold text-primary uppercase tracking-wider">最新</span>
                    </div>
                    <span class="text-sm text-muted-foreground group-hover/latest:text-foreground transition-colors truncate max-w-[200px]">
                        {latestWeekly.title}
                    </span>
                    <Icon name="tabler:arrow-right" class="w-4 h-4 text-muted-foreground group-hover/latest:text-primary group-hover/latest:translate-x-0.5 transition-all" />
                </a>
            )}

            <!-- 右侧: 工具栏 -->
            <div class="flex items-center gap-1.5">
                <!-- 搜索按钮 -->
                <button
                    type="button"
                    class="flex items-center gap-1.5 h-7 px-2.5 rounded border border-border/40 bg-secondary/20 text-muted-foreground hover:text-foreground hover:border-border/60 hover:bg-secondary/40 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
                    aria-label="搜索"
                    data-search-trigger
                    id="header-search-btn"
                >
                    <Icon name="tabler:search" class="w-3.5 h-3.5" />
                    <span class="hidden sm:inline text-xs">搜索</span>
                    <kbd class="hidden lg:inline-flex items-center gap-0.5 px-1 py-0.5 rounded bg-background/60 border border-border/30 text-[9px] font-mono text-muted-foreground">
                        <span>⌘</span><span>K</span>
                    </kbd>
                </button>

                <!-- GitHub -->
                <a
                    class="flex items-center justify-center w-7 h-7 rounded border border-border/40 bg-secondary/20 text-muted-foreground hover:text-foreground hover:border-border/60 hover:bg-secondary/40 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
                    aria-label="GitHub"
                    href="https://github.com/NorthSeacoder/weekly"
                    target="_blank"
                    rel="noopener"
                >
                    <Icon name="tabler:brand-github" class="w-3.5 h-3.5" />
                </a>

                <!-- RSS 订阅 -->
                {showRssFeed && (
                    <a
                        class="flex items-center justify-center w-7 h-7 rounded border border-border/40 bg-secondary/20 text-muted-foreground hover:text-foreground hover:border-border/60 hover:bg-secondary/40 transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary"
                        aria-label="RSS 订阅"
                        href={getAsset('/rss.xml')}
                        target="_blank"
                        rel="noopener"
                    >
                        <Icon name="tabler:rss" class="w-3.5 h-3.5" />
                    </a>
                )}

                <!-- 移动端菜单按钮 -->
                <div class="md:hidden">
                    <ToggleMenu
                        class="flex items-center justify-center w-7 h-7 rounded border border-border/40 bg-secondary/20 text-muted-foreground hover:text-foreground hover:border-border/60 transition-all duration-200 focus:outline-none"
                    />
                </div>
            </div>
        </div>

        <!-- 移动端导航菜单 -->
        <nav class="md:hidden hidden absolute top-full left-4 right-4 mt-2 rounded-xl border border-border/50 bg-background/98 backdrop-blur-xl shadow-2xl shadow-black/20" data-mobile-menu>
            <div class="p-4 space-y-2">
                {links.map(({ text, href, icon }) => (
                    <a
                        class:list={[
                            'flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium',
                            'transition-all duration-200',
                            'focus:outline-none focus-visible:ring-2 focus-visible:ring-primary',
                            {
                                'text-foreground bg-secondary border border-border/50': href === currentPath,
                                'text-muted-foreground hover:text-foreground hover:bg-secondary/50': href !== currentPath,
                            },
                        ]}
                        href={href}
                    >
                        {icon && <Icon name={icon} class="w-5 h-5 opacity-60" />}
                        <span>{text}</span>
                    </a>
                ))}

                <div class="pt-2 mt-2 border-t border-border/50">
                    <button
                        type="button"
                        class="w-full flex items-center justify-between px-4 py-3 rounded-lg text-sm font-medium text-muted-foreground hover:text-foreground hover:bg-secondary/50 transition-all duration-200 focus:outline-none"
                        data-search-trigger
                        id="mobile-search-btn"
                    >
                        <div class="flex items-center gap-3">
                            <Icon name="tabler:search" class="w-5 h-5 opacity-60" />
                            <span>搜索内容</span>
                        </div>
                        <Icon name="tabler:chevron-right" class="w-4 h-4" />
                    </button>
                </div>

                {latestWeekly && (
                    <a
                        href={latestWeekly.permalink}
                        class="flex items-center gap-3 px-4 py-3 rounded-lg bg-primary/5 border border-primary/20 text-sm"
                    >
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
                        </span>
                        <span class="text-muted-foreground">最新:</span>
                        <span class="text-foreground truncate">{latestWeekly.title}</span>
                    </a>
                )}
            </div>
        </nav>
    </div>
</header>

<script>
    function initHeader() {
        const header = document.querySelector('[data-header]') as HTMLElement;
        const headerGlow = document.querySelector('[data-header-glow]') as HTMLElement;
        const mobileMenu = document.querySelector('[data-mobile-menu]') as HTMLElement;
        const toggleButton = document.querySelector('[data-aw-toggle-menu]') as HTMLElement;

        if (!header) return;

        let ticking = false;

        function updateHeaderOnScroll() {
            const scrollY = window.scrollY;

            if (scrollY > 20) {
                header.classList.add('scrolled');
                if (headerGlow) headerGlow.style.opacity = '1';
            } else {
                header.classList.remove('scrolled');
                if (headerGlow) headerGlow.style.opacity = '0';
            }

            ticking = false;
        }

        function handleScroll() {
            if (!ticking) {
                requestAnimationFrame(updateHeaderOnScroll);
                ticking = true;
            }
        }

        function toggleMobileMenu() {
            if (mobileMenu && toggleButton) {
                const isExpanded = toggleButton.getAttribute('aria-expanded') === 'true';
                const newState = !isExpanded;

                toggleButton.setAttribute('aria-expanded', newState.toString());
                toggleButton.classList.toggle('expanded', newState);

                if (newState) {
                    mobileMenu.classList.remove('hidden');
                    mobileMenu.style.opacity = '0';
                    mobileMenu.style.transform = 'translateY(-8px) scale(0.98)';

                    requestAnimationFrame(() => {
                        mobileMenu.style.transition = 'opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1), transform 0.2s cubic-bezier(0.16, 1, 0.3, 1)';
                        mobileMenu.style.opacity = '1';
                        mobileMenu.style.transform = 'translateY(0) scale(1)';
                    });
                } else {
                    mobileMenu.style.transition = 'opacity 0.15s ease-out, transform 0.15s ease-out';
                    mobileMenu.style.opacity = '0';
                    mobileMenu.style.transform = 'translateY(-8px) scale(0.98)';

                    setTimeout(() => {
                        mobileMenu.classList.add('hidden');
                    }, 150);
                }
            }
        }

        window.addEventListener('scroll', handleScroll, { passive: true });

        if (toggleButton) {
            toggleButton.addEventListener('click', toggleMobileMenu);
        }

        document.addEventListener('click', (e) => {
            if (mobileMenu && !mobileMenu.contains(e.target as Node) && !toggleButton?.contains(e.target as Node)) {
                if (!mobileMenu.classList.contains('hidden')) {
                    toggleMobileMenu();
                }
            }
        });

        // 键盘快捷键 Cmd/Ctrl + K 打开搜索
        document.addEventListener('keydown', (e) => {
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                e.preventDefault();
                const searchBtn = document.querySelector('[data-search-trigger]') as HTMLElement;
                searchBtn?.click();
            }
        });

        updateHeaderOnScroll();
    }

    document.addEventListener('DOMContentLoaded', initHeader);
    document.addEventListener('astro:after-swap', initHeader);
</script>

<style>
    .header-container {
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        border-bottom: 1px solid transparent;
    }

    .header-container.scrolled {
        background: hsl(var(--background) / 0.95);
        backdrop-filter: blur(20px) saturate(180%);
        border-bottom: 1px solid hsl(var(--border) / 0.5);
    }

    .header-inner {
        transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    }

    [data-mobile-menu] {
        transform-origin: top center;
    }

    @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
            animation-duration: 0.01ms !important;
            transition-duration: 0.01ms !important;
        }
    }

    @media (prefers-contrast: high) {
        .header-container {
            background: hsl(var(--background)) !important;
            backdrop-filter: none !important;
            border-bottom: 2px solid hsl(var(--border));
        }
    }
</style>
