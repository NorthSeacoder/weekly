---
import { Icon } from 'astro-icon/components';
import { getLatestWeeklyPost } from '@/src/utils/contents/unified-content'

const latestWeekly = await getLatestWeeklyPost()

---

{
  latestWeekly && (
    <div
      class="fixed top-12 left-0 right-0 z-40 hidden md:flex justify-center px-4"
      data-announcement
    >
  <div class="flex items-center gap-3 min-w-0 max-w-4xl w-full px-3 py-2 rounded-xl border border-white/30 dark:border-white/10 bg-white/70 dark:bg-white/5 backdrop-blur-xl shadow-md shadow-black/5">
    <span
      class="bg-foreground text-background font-medium px-2 py-0.5 text-[11px] rounded-md flex-shrink-0"
      >NEW</span
    >
    <a
      href={latestWeekly.permalink}
      class="text-sm text-muted-foreground hover:text-foreground font-medium transition-colors truncate"
    >
      {latestWeekly.title}
    </a>
    <a
      target="_blank"
      rel="noopener"
      class="flex-shrink-0 ml-auto text-muted-foreground hover:text-foreground transition-colors text-xs inline-flex items-center gap-1"
      title="如果你喜欢这个网站，给我一个 Star"
      href="https://github.com/NorthSeacoder/weekly"
    >
      <Icon name="tabler:star" class="w-4 h-4" /> Star
    </a>
  </div>
</div>
  )
}

<script is:inline>
  (function() {
    let abortController;
    function initAnnouncement() {
      if (abortController) abortController.abort();
      abortController = new AbortController();

      const announcement = document.querySelector('[data-announcement]');

      if (!announcement) return;

      // 检查元素是否实际可见
      const isVisible = window.getComputedStyle(announcement).display !== 'none';
      if (!isVisible) return;

      function updateAnnouncement() {
        const scrollY =
          window.pageYOffset || document.documentElement.scrollTop || document.body.scrollTop || 0;
        const maxScroll = 150;
        const progress = Math.min(scrollY / maxScroll, 1);

        announcement.style.transform = 'translateY(' + (-progress * 100) + '%)';
        announcement.style.opacity = (1 - progress).toString();
      }

      // 仅在滚动时更新（用 rAF 合帧），避免常驻每帧循环
      let ticking = false;
      function onScroll() {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          ticking = false;
          updateAnnouncement();
        });
      }

      updateAnnouncement();
      window.addEventListener('scroll', onScroll, { passive: true, signal: abortController.signal });
    }

    // 立即执行
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initAnnouncement);
    } else {
      initAnnouncement();
    }

    // Astro 页面导航
    document.addEventListener('astro:page-load', initAnnouncement);
  })();
</script>
