---
import {Icon} from 'astro-icon/components';
import dayjs from 'dayjs';
import ContentCard from '~/components/common/ContentCard.astro';
import {CATEGORY_SORT_ORDER} from '~/constants/categories';

import type {WeeklyPost, Section} from '@/types/weekly';

type PostNavItem = Pick<WeeklyPost, 'slug' | 'title'>;

export interface Props {
    post: WeeklyPost;
    prevPost?: PostNavItem;
    nextPost?: PostNavItem;
}
const {post, prevPost, nextPost} = Astro.props;
const sections = post.sections ?? [];
const formattedDate = dayjs(post.date).format('YYYY年MM月DD日');

const groupedSections = sections.reduce<Record<string, Section[]>>((acc, section) => {
    const cat = section.category || '其他';
    acc[cat] ||= [];
    acc[cat].push(section);
    return acc;
}, {});

const sortedCategories = Object.keys(groupedSections).sort((a, b) => {
    const ia = CATEGORY_SORT_ORDER.indexOf(a);
    const ib = CATEGORY_SORT_ORDER.indexOf(b);
    return (ia === -1 ? 999 : ia) - (ib === -1 ? 999 : ib);
});
---

<section class='single-post'>
    <article class='single-post__article'>
        <header class='single-post__header'>
            <div class='single-post__meta'>
                <div class='single-post__badge'>
                    <span class='single-post__dot'></span>
                    <span>技术周刊</span>
                </div>

                <h1 class='single-post__title'>{post.title}</h1>

                <div class='single-post__info'>
                    <span class='single-post__info-item'>
                        <Icon name='tabler:calendar' class='w-4 h-4' />
                        <time datetime={String(post.date)}>{formattedDate}</time>
                    </span>
                    {post.wordCount && (
                        <span class='single-post__info-item'>
                            <Icon name='tabler:file-word' class='w-4 h-4' />
                            {post.wordCount.toLocaleString()} 字
                        </span>
                    )}
                    <span class='single-post__info-item'>
                        <Icon name='tabler:list' class='w-4 h-4' />
                        {sections.length} 条内容
                    </span>
                </div>
            </div>
        </header>

        <div class='single-post__content'>
            {sortedCategories.map((category) => (
                <section class='category-group'>
                    <h2 class='category-group__title'>{category}</h2>
                    <div class='category-group__cards'>
                        {groupedSections[category].map((section) => (
                            <ContentCard section={section} featured={section.featured || false} />
                        ))}
                    </div>
                </section>
            ))}
        </div>

        <div class='single-post__nav'>
            <nav class='post-nav'>
                {prevPost ? (
                    <a href={`/weekly/${prevPost.slug}`} class='post-nav__link post-nav__link--prev'>
                        <Icon name='tabler:chevron-left' class='w-5 h-5 post-nav__icon' />
                        <div class='post-nav__text'>
                            <span class='post-nav__label'>上一期</span>
                            <span class='post-nav__title'>{prevPost.title}</span>
                        </div>
                    </a>
                ) : <div />}

                <a href='/weekly' class='post-nav__all'>
                    <Icon name='tabler:layout-grid' class='w-4 h-4' />
                    所有周刊
                </a>

                {nextPost ? (
                    <a href={`/weekly/${nextPost.slug}`} class='post-nav__link post-nav__link--next'>
                        <div class='post-nav__text' style='text-align:right'>
                            <span class='post-nav__label'>下一期</span>
                            <span class='post-nav__title'>{nextPost.title}</span>
                        </div>
                        <Icon name='tabler:chevron-right' class='w-5 h-5 post-nav__icon' />
                    </a>
                ) : <div />}
            </nav>
        </div>

        <footer class='single-post__footer'>
            <button
                onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
                class='single-post__back-top'
                aria-label='回到顶部'>
                <Icon name='tabler:arrow-up' class='w-4 h-4' />
                <span>回到顶部</span>
            </button>
        </footer>
    </article>
</section>

<style>
    .single-post {
        min-height: 100vh;
        background: transparent;
    }

    .single-post__article {
        max-width: 60rem;
        margin: 0 auto;
        padding: 6rem 1.5rem 5rem;
    }

    .single-post__header {
        margin-bottom: 2.75rem;
        padding: clamp(1.25rem, 4vw, 2rem);
        border-radius: 0.75rem;
        background: var(--neu-surface-gradient);
        box-shadow: var(--shadow-lg);
    }

    .single-post__meta {
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .single-post__badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.375rem 0.75rem;
        border-radius: 0.5rem;
        background: var(--neu-inset-gradient);
        box-shadow: var(--shadow-inner);
        font-size: 0.875rem;
        font-weight: 600;
        color: hsl(var(--primary));
    }

    .single-post__dot {
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        background: hsl(var(--primary));
    }

    .single-post__title {
        font-size: clamp(1.75rem, 4vw, 2.75rem);
        font-weight: 700;
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: hsl(var(--foreground));
        text-wrap: balance;
        margin: 0;
    }
    .single-post__info {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
        font-size: 0.875rem;
        color: hsl(var(--muted-foreground));
    }

    .single-post__info-item {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        padding: 0.375rem 0.625rem;
        border-radius: 0.5rem;
        background: var(--neu-surface-gradient);
        box-shadow: var(--shadow-sm);
    }

    .single-post__content {
        display: flex;
        flex-direction: column;
        gap: 2.5rem;
    }

    .category-group__title {
        display: flex;
        align-items: center;
        gap: 0.625rem;
        font-size: 1rem;
        font-weight: 800;
        color: hsl(var(--foreground));
        margin: 0 0 1rem;
        letter-spacing: 0.02em;
    }

    .category-group__title::before {
        content: '';
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 999px;
        background: hsl(var(--primary));
        box-shadow: 0 0 0 4px hsl(var(--primary) / 0.12);
        flex: 0 0 auto;
    }

    .category-group__title::after {
        content: '';
        height: 1px;
        flex: 1 1 auto;
        background: hsl(var(--border) / 0.7);
    }

    .category-group__cards {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .single-post__nav {
        margin-top: 3rem;
    }

    .post-nav {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 1rem;
        align-items: stretch;
    }

    .post-nav__link {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1rem 1.25rem;
        border-radius: 0.75rem;
        background: var(--neu-surface-gradient);
        box-shadow: var(--shadow-sm);
        text-decoration: none;
        color: hsl(var(--foreground));
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .post-nav__link:hover {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
    }

    .post-nav__link--next {
        justify-content: flex-end;
    }

    .post-nav__icon {
        color: hsl(var(--muted-foreground));
        flex-shrink: 0;
    }

    .post-nav__text {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 0;
    }

    .post-nav__label {
        font-size: 0.75rem;
        color: hsl(var(--muted-foreground));
    }

    .post-nav__title {
        font-size: 0.875rem;
        font-weight: 600;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .post-nav__all {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.25rem;
        border-radius: 0.75rem;
        background: var(--neu-inset-gradient);
        box-shadow: var(--shadow-inner);
        font-size: 0.875rem;
        font-weight: 600;
        color: hsl(var(--muted-foreground));
        text-decoration: none;
        transition: color 0.2s ease, box-shadow 0.2s ease;
    }

    .post-nav__all:hover {
        color: hsl(var(--foreground));
        box-shadow: var(--shadow-sm);
    }

    .single-post__footer {
        margin-top: 3rem;
        display: flex;
        justify-content: center;
    }

    .single-post__back-top {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        border: 0;
        border-radius: 0.75rem;
        background: var(--neu-surface-gradient);
        box-shadow: var(--shadow-sm);
        color: hsl(var(--muted-foreground));
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: color 0.15s ease, box-shadow 0.15s ease;
    }

    .single-post__back-top:hover {
        color: hsl(var(--foreground));
        box-shadow: var(--shadow-md);
    }

    @media (max-width: 640px) {
        .single-post__article {
            padding: 4.75rem 1rem 4rem;
        }

        .post-nav {
            grid-template-columns: 1fr;
        }

        .post-nav__link--next {
            justify-content: flex-start;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .single-post *,
        .single-post *::before,
        .single-post *::after {
            transition: none;
        }
    }
</style>
