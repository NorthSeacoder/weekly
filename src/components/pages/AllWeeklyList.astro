---
import {getWeeklyPosts} from '~/utils/contents/unified-content';
import StatCard from '~/components/ui/StatCard.astro';
import Button from '~/components/ui/Button.astro';

const weeklyList = await getWeeklyPosts();
const groupedByYear = Object.entries(
    weeklyList.reduce<Record<string, typeof weeklyList>>((acc, weekly) => {
        const year = new Date(weekly.date).getFullYear().toString();
        acc[year] ||= [];
        acc[year].push(weekly);
        return acc;
    }, {})
).sort((a, b) => Number(b[0]) - Number(a[0]));

const topTags = Array.from(
    weeklyList
        .flatMap((weekly) => weekly.tags || [])
        .reduce<Map<string, number>>((acc, tag) => {
            acc.set(tag, (acc.get(tag) || 0) + 1);
            return acc;
        }, new Map())
        .entries()
)
    .sort((a, b) => b[1] - a[1])
    .slice(0, 6);
---

<section class='archive-section'>
    <div class='archive-shell'>
        <header class='archive-hero'>
            <div class='archive-copy'>
                <p class='archive-kicker'>Archive</p>
                <h1>按时间回看每一期，再顺着主题继续发现。</h1>
                <p class='archive-lead'>
                    归档按时间展开，主题标签作为辅助线索，便于回看与检索。
                </p>

                <dl class='archive-metrics'>
                    <div>
                        <dt>总期数</dt>
                        <dd>{weeklyList.length}</dd>
                    </div>
                    <div>
                        <dt>归档年份</dt>
                        <dd>{groupedByYear.length}</dd>
                    </div>
                    <div>
                        <dt>状态</dt>
                        <dd>每周更新</dd>
                    </div>
                </dl>
            </div>

            <aside class='archive-aside'>
                <div class='archive-panel'>
                    <p class='panel-title'>常见主题</p>
                    {
                        topTags.length > 0 ? (
                            <div class='tag-cloud'>
                                {topTags.map(([tag, count]) => (
                                    <span class='tag-pill'>{tag} · {count}</span>
                                ))}
                            </div>
                        ) : (
                            <p class='panel-empty'>暂时还没有可用标签。</p>
                        )
                    }
                    <Button href='/' variant='secondary' size='lg'>返回首页</Button>
                </div>
            </aside>
        </header>

        {
            weeklyList.length === 0 ? (
                <div class='archive-empty'>
                    <h2>归档暂时为空</h2>
                    <p>周刊内容还在整理中，稍后再来看。</p>
                    <Button href='/' variant='primary' size='lg'>回到首页</Button>
                </div>
            ) : (
                <div class='archive-years'>
                    {groupedByYear.map(([year, items]) => (
                        <section class='year-block' aria-labelledby={`year-${year}`}>
                            <div class='year-head'>
                                <div>
                                    <p class='year-label'>Year</p>
                                    <h2 id={`year-${year}`}>{year}</h2>
                                </div>
                                <p class='year-count'>{items.length} 期归档</p>
                            </div>

                            <div class='year-grid'>
                                {items.map((weekly) => (
                                    <a href={weekly.permalink} class='block h-full focus:outline-none rounded-lg'>
                                        <StatCard
                                            title={weekly.title}
                                            date={weekly.date}
                                            desc={weekly.desc || '精选本周前端技术内容'}
                                            cover={weekly.cover}
                                            tags={weekly.tags}
                                            showTags={true}
                                            eyebrow={year}
                                        />
                                    </a>
                                ))}
                            </div>
                        </section>
                    ))}
                </div>
            )
        }

        <div class='archive-footer'>
            <button
                onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
                class='back-to-top'
                aria-label='回到顶部'>
                回到顶部
            </button>
        </div>
    </div>
</section>

<style>
    .archive-section {
        min-height: 100vh;
        padding: 3rem 1.5rem 5rem;
        background:
            radial-gradient(circle at top left, hsl(var(--primary) / 0.07), transparent 24%),
            hsl(var(--background));
    }

    .archive-shell {
        max-width: 72rem;
        margin: 0 auto;
        display: grid;
        gap: 2.5rem;
    }

    .archive-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(18rem, 22rem);
        gap: 2rem;
        align-items: start;
    }

    .archive-copy {
        display: grid;
        gap: 1.25rem;
    }

    .archive-kicker,
    .year-label {
        margin: 0;
        color: hsl(var(--primary));
        font-size: 0.875rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .archive-copy h1 {
        margin: 0;
        max-width: 12ch;
        font-size: clamp(2.75rem, 6vw, 5rem);
        line-height: 0.98;
        letter-spacing: -0.045em;
        text-wrap: balance;
    }

    .archive-lead {
        max-width: 38rem;
        margin: 0;
        color: hsl(var(--muted-foreground));
        font-size: 1.0625rem;
        line-height: 1.8;
    }

    .archive-metrics {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin: 0;
        padding-top: 0.5rem;
    }

    .archive-metrics div {
        padding-top: 1rem;
        border-top: 1px solid hsl(var(--border));
    }

    .archive-metrics dt {
        margin-bottom: 0.5rem;
        color: hsl(var(--muted-foreground));
        font-size: 0.8125rem;
    }

    .archive-metrics dd {
        margin: 0;
        font-size: 1.125rem;
        font-weight: 700;
        color: hsl(var(--foreground));
    }

    .archive-panel {
        display: grid;
        gap: 1rem;
        padding: 1.25rem;
        border: 1px solid hsl(var(--border));
        border-radius: 1.25rem;
        background: linear-gradient(180deg, hsl(var(--surface)) 0%, hsl(var(--background)) 100%);
    }

    .panel-title {
        margin: 0;
        font-size: 0.9375rem;
        font-weight: 700;
        color: hsl(var(--foreground));
    }

    .panel-empty {
        margin: 0;
        color: hsl(var(--muted-foreground));
        font-size: 0.9375rem;
    }

    .tag-cloud {
        display: flex;
        flex-wrap: wrap;
        gap: 0.625rem;
    }

    .tag-pill {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.75rem;
        border-radius: 999px;
        background: hsl(var(--surface-elevated));
        color: hsl(var(--muted-foreground));
        font-size: 0.875rem;
        line-height: 1;
    }

    .archive-years {
        display: grid;
        gap: 3rem;
    }

    .year-block {
        display: grid;
        gap: 1.5rem;
    }

    .year-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
        padding-bottom: 1rem;
        border-bottom: 1px solid hsl(var(--border));
    }

    .year-head h2 {
        margin: 0.4rem 0 0;
        font-size: clamp(2rem, 4vw, 3rem);
        line-height: 1;
        letter-spacing: -0.04em;
    }

    .year-count {
        margin: 0;
        color: hsl(var(--muted-foreground));
        font-size: 0.9375rem;
    }

    .year-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .archive-empty {
        display: grid;
        justify-items: center;
        gap: 1rem;
        padding: 4rem 1.5rem;
        border: 1px dashed hsl(var(--border));
        border-radius: 1.5rem;
        text-align: center;
    }

    .archive-empty h2,
    .archive-empty p {
        margin: 0;
    }

    .archive-empty p {
        max-width: 34rem;
        color: hsl(var(--muted-foreground));
        line-height: 1.75;
    }

    .archive-footer {
        display: flex;
        justify-content: center;
        padding-top: 0.5rem;
    }

    .back-to-top {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 2.75rem;
        padding: 0.625rem 1rem;
        border: 1px solid hsl(var(--border));
        border-radius: 999px;
        background: hsl(var(--surface));
        color: hsl(var(--muted-foreground));
        font-size: 0.9375rem;
        font-weight: 600;
        transition:
            color 150ms ease,
            background-color 150ms ease,
            border-color 150ms ease;
    }

    .back-to-top:hover {
        background: hsl(var(--surface-hover));
        border-color: hsl(var(--border));
        color: hsl(var(--foreground));
    }

    @media (max-width: 960px) {
        .archive-hero {
            grid-template-columns: 1fr;
        }

        .archive-metrics {
            grid-template-columns: 1fr;
        }

        .archive-aside {
            max-width: 34rem;
        }
    }

    @media (max-width: 640px) {
        .archive-section {
            padding: 2rem 1rem 4rem;
        }

        .archive-shell {
            gap: 2rem;
        }

        .archive-copy h1 {
            max-width: 9ch;
            font-size: clamp(2.3rem, 12vw, 3.5rem);
        }

        .archive-lead {
            font-size: 1rem;
            line-height: 1.65;
        }

        .archive-panel {
            padding: 1rem;
        }

        .tag-cloud {
            gap: 0.5rem;
        }

        .tag-pill {
            font-size: 0.8125rem;
        }

        .year-head {
            flex-direction: column;
            align-items: start;
        }

        .year-head h2 {
            font-size: 1.75rem;
        }

        .year-grid {
            grid-template-columns: 1fr;
            gap: 1rem;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .archive-section *,
        .archive-section *::before,
        .archive-section *::after {
            transition-duration: 0.01ms !important;
        }
    }
</style>
