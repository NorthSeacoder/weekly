---
import {cn} from '~/utils/utils';
import Tags from './Tags.astro';
import dayjs from 'dayjs';
import {Icon} from 'astro-icon/components';
import WeeklyCover from '~/components/widgets/WeeklyCover.astro';
import type {WeeklyCoverConfig} from '../../../types/weekly';

interface StatCardProps {
    title: string;
    date: string | Date;
    tags?: string[];
    desc?: string;
    coverConfig?: WeeklyCoverConfig;
    showTags?: boolean;
    eyebrow?: string;
    featured?: boolean;
}

const {title, date, desc, tags = [], coverConfig, showTags = true, eyebrow = 'Weekly', featured = false} = Astro.props as StatCardProps;

const formattedDate = new Date(date).toLocaleDateString('zh-CN', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
});

const isNew = dayjs(date).isAfter(dayjs().subtract(2, 'week'));

const cardClasses = cn(
    'weekly-stat-card group relative h-full',
    'rounded-lg overflow-hidden',
    'transition-all duration-200 ease-out',
    'cursor-pointer',
    'focus-within:ring-2 focus-within:ring-primary/50 focus-within:ring-offset-2 focus-within:ring-offset-background'
);
---

<div class={cardClasses}>
    <div
        class='absolute inset-0 rounded-lg pointer-events-none ring-1 ring-inset ring-white/35 dark:ring-white/5 transition-colors duration-200 z-20 group-hover:ring-primary/20'>
    </div>

    {
        isNew && (
            <div class='absolute top-3 right-3 z-30'>
                <span class='inline-flex items-center px-2 py-0.5 rounded-md text-[10px] font-bold tracking-wider uppercase bg-primary text-primary-foreground shadow-md shadow-primary/20'>
                    New
                </span>
            </div>
        )
    }

    <!-- 内容区域 -->
    <div class:list={['relative z-10 h-full flex flex-col', { 'min-h-full': featured }]}>
        <!-- Cover -->
        <div class:list={['stat-card-cover relative overflow-hidden bg-surface', featured ? 'aspect-[16/9]' : 'aspect-[40/21]']}>
            {coverConfig ? (
                <WeeklyCover config={coverConfig} variant="card" />
            ) : (
                <div class="w-full h-full bg-gradient-to-br from-[hsl(var(--primary)/0.2)] to-[hsl(var(--primary)/0.05)]"></div>
            )}
        </div>

        <div class='flex flex-col flex-1 p-4 gap-3'>
            <!-- Eyebrow -->
            <div class='flex items-center gap-2 text-xs text-muted-foreground/80'>
                <span class='issue-eyebrow inline-flex rounded-md px-2 py-1 font-semibold tracking-[0.08em]'>{eyebrow}</span>
            </div>

            <!-- Title -->
            <h3
                class='text-base font-bold text-foreground leading-snug line-clamp-2 group-hover:text-primary transition-colors duration-200'>
                {title}
            </h3>

            <!-- Content -->
            <div class='mt-auto space-y-4'>
                {
                    desc && (
                        <p class='text-sm text-muted-foreground leading-relaxed line-clamp-2 group-hover:text-muted-foreground/80 transition-colors'>
                            {desc}
                        </p>
                    )
                }

                {
                    showTags && tags.length > 0 && (
                        <div class='flex flex-wrap gap-1.5 pt-1'>
                            <Tags tags={tags} maxVisible={3} variant='minimal' size='sm' compact />
                        </div>
                    )
                }

                <!-- Footer -->
                <div class='flex items-center justify-between pt-3 border-t border-border/45 text-sm'>
                    <time datetime={date.toString()} class='text-muted-foreground/70 font-mono text-xs'
                        >{formattedDate}</time
                    >
                    <span
                        class='inline-flex items-center gap-1.5 text-muted-foreground group-hover:text-primary transition-colors duration-200'>
                        <span class='text-xs font-semibold'>阅读</span>
                        <Icon
                            name='tabler:arrow-right'
                            class='w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1'
                        />
                    </span>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Typography optimization */
    h3 {
        text-rendering: optimizeLegibility;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-feature-settings: 'cv02', 'cv03', 'cv04', 'cv11';
    }

    .weekly-stat-card {
        background: var(--neu-surface-gradient);
        box-shadow: var(--shadow-md);
    }

    .weekly-stat-card:hover {
        box-shadow: var(--shadow-lg);
    }

    .stat-card-cover {
        border-radius: 0.5rem 0.5rem 0 0;
    }

    .stat-card-cover :global(.weekly-cover),
    .stat-card-cover :global(.weekly-cover__svg) {
        border-radius: inherit;
    }

    .issue-eyebrow {
        background: var(--neu-inset-gradient);
        box-shadow: var(--shadow-inner);
    }

    /* Text truncation */
    .line-clamp-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    /* Reduced motion */
    @media (prefers-reduced-motion: reduce) {
        .group,
        .group * {
            transition: none !important;
            animation: none !important;
        }
    }

    /* Touch device optimization */
    @media (hover: none) {
        .group:hover {
            transform: none;
        }
    }

    /* High contrast mode */
    @media (prefers-contrast: high) {
        .group {
            border-width: 2px;
            background: hsl(var(--card));
        }
    }
</style>
